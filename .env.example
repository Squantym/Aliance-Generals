# ===================================================================
# .env.example — скопируйте в .env и заполните перед запуском
# Файл .env НЕЛЬЗЯ публиковать на GitHub (добавьте в .gitignore)!
# ===================================================================

# --- Порт сервера (по умолчанию 3000) ---
# PORT=3000

# --- MongoDB ---
# Строка подключения с MongoDB Atlas (бесплатный тариф M0):
# 1. Зарегистрируйтесь на mongodb.com/cloud/atlas
# 2. Создайте кластер (Free / M0)
# 3. Нажмите «Connect → Drivers», скопируйте строку вида:
#    mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/
# 4. Вставьте сюда:
# MONGODB_URI=mongodb+srv://myuser:mypassword@cluster0.xxxxx.mongodb.net/

# Имя базы данных (по умолчанию generals)
# MONGODB_DB=generals

# --- Email-подтверждение (resend.com) ---
# Без этих переменных почта НЕ отправляется.
# В режиме разработки (без RESEND_API_KEY) почта считается подтверждённой
# автоматически, а ссылка выводится в консоль сервера.
#
# Шаги:
# 1. Зарегистрируйтесь на resend.com (бесплатно, 3000 писем/мес)
# 2. Создайте API Key (Resend Dashboard → API Keys)
# 3. Добавьте свой домен (Resend Dashboard → Domains) ИЛИ используйте
#    тестовый адрес onboarding@resend.dev (только для yourname@example.com)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Адрес отправителя. Если используете свой домен:
# EMAIL_FROM=Генералы <noreply@yourdomain.com>
# Если тестируете без своего домена:
# EMAIL_FROM=Генералы <onboarding@resend.dev>

# Публичный URL игры (для ссылок в письмах подтверждения).
# На хостинге Render это будет что-то вроде:
# APP_URL=https://generals-game.onrender.com
APP_URL=http://localhost:3000

# ---------- PUSH-УВЕДОМЛЕНИЯ НА ТЕЛЕФОН (Web Push) ----------
# Работают «из коробки»: если ключи не заданы, сервер сгенерирует их сам
# при первом запуске и сохранит в БД (коллекция pushconfig).
#
# ВАЖНО: ключи должны быть ПОСТОЯННЫМИ. Если их поменять — все подписки
# игроков станут недействительными, и уведомления перестанут приходить.
# Задавать здесь имеет смысл, только если хочешь хранить их в .env,
# а не в БД (например, при переезде базы).
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# Контакт для push-сервисов (Google/Mozilla) на случай проблем с рассылкой.
# PUSH_CONTACT=mailto:admin@yourdomain.com
